---
const navItems = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about" },
  { label: "Services", href: "/services" },
  { label: "Blog", href: "/blog" },
  { label: "Contact", href: "/contact" },
];
---

<a 
  href="#main-content" 
  class="absolute -top-full left-4 focus:top-0 bg-linear-brand text-brand-dark font-semibold px-4 py-2 rounded-b-lg text-sm z-9999 transition-all ease-spring"
>
  Skip to content
</a>

<header id="site-navbar" class="sticky top-0 z-50 glassmorphism shadow-trust">
  <input type="checkbox" id="menu-toggle-input" class="hidden peer" />

  <nav class="section-container h-17 flex items-center justify-between lg:grid lg:grid-cols-[1fr_auto_1fr] gap-8" aria-label="Main navigation">

    <div class="flex items-center order-1">
      <a href="/" class="flex items-center gap-2.5 no-underline group" aria-label="Home">
        <div class="w-9 h-9 rounded-[10px] bg-linear-brand flex items-center justify-center shadow-sm transition-all duration-500 ease-spring group-hover:-rotate-6">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" class="text-brand-dark">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
        </div>
        <span class="font-bold text-[1.2rem] text-brand-dark tracking-tight">
          Brand<span class="text-brand-primary">.</span>
        </span>
      </a>
    </div>

    <ul class="hidden lg:flex items-center justify-center gap-1 order-2">
      {navItems.map((item) => (
        <li>
          <a href={item.href} class="relative font-medium text-[0.9rem] text-gray-500 px-3.5 py-2 rounded-lg transition-all duration-300 ease-spring hover:text-brand-dark hover:bg-brand-primary/10 group">
            {item.label}
            <span class="absolute bottom-1 left-1/2 -translate-x-1/2 w-4 h-0.5 rounded-full bg-brand-primary scale-x-0 group-hover:scale-x-100 transition-transform duration-300"></span>
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center justify-end gap-3 order-3">
      <div class="hidden lg:flex items-center gap-3">
        <form action="/search" class="relative flex items-center group/search" role="search">
          <input 
            type="search" 
            placeholder="Search…" 
            class="w-45 pl-4 pr-4 py-2 text-sm rounded-full border border-brand-primary/20 bg-brand-primary/5 outline-none focus:w-60 focus:bg-white focus:border-brand-primary transition-all duration-500 ease-spring" 
            aria-label="Search site content"
          />
        </form>
        <a href="/get-started" class="font-semibold text-sm px-5 py-2 rounded-full bg-linear-brand text-brand-dark shadow-sm hover:scale-105 transition-all duration-500 ease-spring">
          Get Started
        </a>
      </div>

      <label for="menu-toggle-input" class="lg:hidden flex flex-col justify-center gap-1.25 w-10 h-10 cursor-pointer p-2 rounded-xl hover:bg-gray-100 transition-colors" aria-label="Toggle menu">
        <span class="w-6 h-0.5 bg-brand-dark rounded-sm transition-all duration-500 ease-spring [input:checked~nav_&]:translate-y-1.75 [input:checked~nav_&]:rotate-45"></span>
        <span class="w-4 h-0.5 bg-brand-dark rounded-sm transition-all duration-300 [input:checked~nav_&]:opacity-0"></span>
        <span class="w-6 h-0.5 bg-brand-dark rounded-sm transition-all duration-500 ease-spring [input:checked~nav_&]:-translate-y-1.75 [input:checked~nav_&]:-rotate-45"></span>
      </label>
    </div>
  </nav>

  <div class="lg:hidden fixed inset-x-4 top-19 glassmorphism shadow-trust border border-brand-primary/20 rounded-2xl p-4 opacity-0 -translate-y-4 pointer-events-none transition-all duration-500 ease-spring peer-checked:opacity-100 peer-checked:translate-y-0 peer-checked:pointer-events-auto">
    <div class="flex flex-col gap-1">
      {navItems.map((item) => (
        <a href={item.href} class="px-4 py-3 rounded-xl font-medium text-gray-600 hover:bg-brand-primary/10 hover:text-brand-dark transition-all">{item.label}</a>
      ))}
      <div class="h-px bg-gray-100 my-2"></div>
      <a href="/get-started" class="w-full py-4 rounded-xl bg-linear-brand text-brand-dark font-bold text-center shadow-sm">
        Get Started
      </a>
    </div>
  </div>
</header>