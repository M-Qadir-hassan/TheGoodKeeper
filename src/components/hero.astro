---
// src/components/Hero.astro
const { title, text, primaryBtn , SecondaryBtn  } = Astro.props;

---
<section class="relative pb-16 pt-50 px-5 text-black overflow-hidden">
  <div class="max-w-5xl mx-auto relative z-10">
    <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight mb-4">{title}</h1>
    <p class="text-lg md:text-xl text-black max-w-2xl mb-8">{text}</p>
    <div class="flex gap-4">
      <a href="/blog" class="bg-white text-indigo-700 px-6 py-3 rounded-lg font-semibold hover:bg-indigo-50 transition">
        {primaryBtn}
      </a>
      <a href="/about" class="border border-indigo-300 px-6 py-3 rounded-lg font-semibold hover:bg-indigo-600 transition">
        {SecondaryBtn}
        
      </a>
    </div>
  </div>
  <div class="absolute top-0 right-0 -translate-y-12 translate-x-12 blur-3xl opacity-20 bg-white w-64 h-64 rounded-full"></div>
</section>